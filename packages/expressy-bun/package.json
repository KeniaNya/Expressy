{
  "name": "expressy-bun",
  "version": "0.3.0",
  "description": "Express-like micro framework built directly on Bun.serve. Zero dependencies, no build step.",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./index.cjs",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "index.cjs",
    "MIGRATION.md"
  ],
  "scripts": {
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KeniaNya/Expressy.git",
    "directory": "packages/expressy-bun"
  },
  "homepage": "https://github.com/KeniaNya/Expressy#readme",
  "bugs": {
    "url": "https://github.com/KeniaNya/Expressy/issues"
  },
  "keywords": [
    "bun",
    "http",
    "server",
    "router",
    "express",
    "middleware",
    "framework",
    "zero-dependencies"
  ],
  "license": "MIT"
}
